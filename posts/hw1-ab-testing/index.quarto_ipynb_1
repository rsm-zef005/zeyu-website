    "def peeking_experiment(pi=0.20, total_n=1000, step=100):\n",
    "    A_null = np.random.binomial(1, pi, total_n)\n",
    "    B_null = np.random.binomial(1, pi, total_n)\n",
    "\n",
    "    for n_i in range(step, total_n + 1, step):\n",
    "        A_sub = A_null[:n_i]\n",
    "        B_sub = B_null[:n_i]\n",
    "\n",
    "        theta_hat_i = A_sub.mean() - B_sub.mean()\n",
    "\n",
    "        se_i = np.sqrt(\n",
    "            A_sub.mean() * (1 - A_sub.mean()) / n_i +\n",
    "            B_sub.mean() * (1 - B_sub.mean()) / n_i\n",
    "        )\n",
    "\n",
    "        if se_i == 0:\n",
    "            continue\n",
    "\n",
    "        z_i = theta_hat_i / se_i\n",
    "        p_i = 2 * (1 - norm.cdf(abs(z_i)))\n",
    "\n",
    "        if p_i < 0.05:\n",
    "            return 1\n",
    "\n",
    "    return 0\n",
    "\n",
    "np.random.seed(495)\n",
    "peeking_results = np.array([peeking_experiment() for _ in range(10000)])\n",
    "false_positive_rate = peeking_results.mean()\n",
    "\n",
    "false_positive_rate"
   ]
